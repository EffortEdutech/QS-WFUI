{
  "name": "@lados/pack-sdk",
  "version": "2.0.0",
  "description": "LADOS V4 Pack SDK — types and utilities for building @lados node packs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lados/node-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
