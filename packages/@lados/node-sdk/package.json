{
  "name": "@lados/node-sdk",
  "version": "2.0.0",
  "description": "Lados Node SDK V2 — NodeContext, BaseNode, and execution types for building Lados nodes",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lados/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
