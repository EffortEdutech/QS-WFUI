# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.

# ── AI Provider ──
OPENAI_API_KEY=sk-proj-...

# ── Supabase (copy from .env.local or Supabase dashboard) ──
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Storage ──
STORAGE_BUCKET=lados-documents

# ── App ──
APP_URL=http://localhost:3000
PORT=4000
NODE_ENV=development

# ── Queue (Phase 12 — Async Execution Queue) ──
# Upstash Redis: get URL from upstash.com (free tier works for MVP)
# Format: rediss://default:<password>@<host>.upstash.io:6379
# If not set, execution falls back to in-process (dev mode without Redis)
REDIS_URL=rediss://default:REPLACE_WITH_UPSTASH_PASSWORD@REPLACE.upstash.io:6379
